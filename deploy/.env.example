# Copy to /opt/scorepilot/.env on the server and fill in real values.
# This file lives ONLY on the server; never commit the real .env.
#
# TLS and the public hostname are handled by the host's existing reverse proxy
# (e.g. Caddy), which routes the subdomain to the app on APP_PORT - so no DOMAIN
# or certificate settings are needed here.

# Loopback port the app is published on (the host proxy forwards to it).
# Change only if this port is already taken on the host.
APP_PORT=8003

# Postgres credentials (used by both the db and app services).
# Use a URL-SAFE password - letters and digits only, e.g. `openssl rand -hex 24`.
# Characters like $ % @ : / corrupt the connection URL (compose interpolates the
# password into SCOREPILOT_DATABASE_URL verbatim).
POSTGRES_USER=scorepilot
POSTGRES_PASSWORD=change-me-to-a-long-random-hex-secret
POSTGRES_DB=scorepilot

# --- App hardening (recommended for any public deploy) ---
# HTTP Basic auth gate. The app has no login of its own otherwise, so set a
# password here (or put basic_auth in the host Caddy) before exposing it.
# Leave both unset for a private/local instance. Generate with `openssl rand -hex 24`.
SCOREPILOT_AUTH_USERNAME=scorepilot
SCOREPILOT_AUTH_PASSWORD=change-me-to-a-long-random-secret

# Hide the interactive API docs and OpenAPI schema in production.
SCOREPILOT_DOCS_ENABLED=false

# Resource caps (defaults shown). Bound memory from large or expansive uploads.
# SCOREPILOT_MAX_UPLOAD_MB=100
# SCOREPILOT_MAX_CELLS=50000000
