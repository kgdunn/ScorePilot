# Copy to /opt/scorepilot/.env on the server and fill in real values.
# This file lives ONLY on the server; never commit the real .env.
#
# TLS and the public hostname are handled by the host's existing reverse proxy
# (e.g. Caddy), which routes the subdomain to the app on APP_PORT - so no DOMAIN
# or certificate settings are needed here.

# Loopback port the app is published on (the host proxy forwards to it).
# Change only if this port is already taken on the host.
APP_PORT=8003

# Postgres credentials (used by both the db and app services).
# Use a password WITHOUT '$' characters (compose treats $ as interpolation).
POSTGRES_USER=scorepilot
POSTGRES_PASSWORD=change-me-to-a-long-random-secret
POSTGRES_DB=scorepilot
